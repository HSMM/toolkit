# =============================================================
# Toolkit — environment variables
# Copy to .env and fill in real values. DO NOT commit .env.
# =============================================================

# --- PostgreSQL ---
POSTGRES_DB=toolkit
POSTGRES_USER=toolkit
POSTGRES_PASSWORD=change-me-please
POSTGRES_PORT=5432

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=toolkit-minio-root
MINIO_ROOT_PASSWORD=change-me-please-min-8-chars
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Bucket names
MINIO_BUCKET_RECORDINGS=recordings
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_BACKUPS=backups

# --- PostgreSQL backup ---
# Полный pg_dump в MinIO бакет MINIO_BUCKET_BACKUPS, retention в днях.
# RPO ≤ 24ч (см. ТЗ MVP 5.3) при BACKUP_INTERVAL_SECONDS=86400.
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_SECONDS=86400
ON_START_BACKUP=0                # 1 — снять бэкап сразу при старте контейнера

# --- OpenSearch ---
OPENSEARCH_PORT=9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=ChangeMeStrong123!

# --- Redis (coordination для LiveKit Egress) ---
REDIS_PORT=6379

# --- LiveKit ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-at-least-32-chars-long-secret
LIVEKIT_HTTP_PORT=7880
LIVEKIT_TCP_PORT=7881
# UDP range for media — prod: 50000-60000; dev: уже в livekit.yaml
# Внутренний URL (api → livekit) для Twirp/REST; в docker-compose резолвится автоматически
LIVEKIT_URL=http://livekit:7880
# Публичный WSS URL для браузеров (то, что фронт передаёт в LiveKitRoom). В dev — ws://localhost:7880
LIVEKIT_PUBLIC_WS_URL=ws://localhost:7880

# --- coturn ---
COTURN_STATIC_AUTH_SECRET=change-me-turn-secret-at-least-32-chars
COTURN_REALM=turn.example.com
COTURN_PORT=3478
# External IP — в prod это публичный IP app-сервера; в dev — любой доступный
COTURN_EXTERNAL_IP=127.0.0.1

# --- Grafana ---
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=change-me-admin-password

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Loki ---
LOKI_PORT=3100

# --- Internal web (nginx) ---
WEB_PORT=8080
# В prod: внутренний интерфейс app-сервера, на котором слушает web-контейнер
# (внешний reverse-proxy с TLS-терминацией обращается сюда).
# В dev — оставить пустым / 0.0.0.0 для удобного локального доступа.
APP_BIND_ADDRESS=
# Порт, на котором web-контейнер публикуется в prod (за внешним прокси).
APP_BIND_PORT=18001

# =============================================================
# Application secrets — нужны когда появится backend-код
# =============================================================

# Bitrix24 local app (portal.example.com)
BITRIX_PORTAL_URL=https://portal.example.com
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=
BITRIX_APP_TOKEN=

# FreePBX WebRTC
FREEPBX_WSS_URL=
FREEPBX_EXTENSION=
FREEPBX_EXTENSION_PASSWORD=

# Telegram user-client integration (MTProto, not Bot API)
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
TELEGRAM_SESSION_ENCRYPTION_KEY=generate-a-32-byte-base64-key
TELEGRAM_SYNC_ENABLED=true
TELEGRAM_RETENTION_DAYS=180
TELEGRAM_WORKER_URL=http://telegram-worker:8090

# Viber experimental user-client PoC (unofficial, isolated worker).
VIBER_USER_CLIENT_EXPERIMENTAL=false
VIBER_WORKER_URL=http://viber-worker:8091
VIBER_WORKER_PORT=8091
VIBER_ENTRY_URL=https://account.viber.com/
VIBER_QR_SELECTOR=
VIBER_HEADLESS=true
VIBER_LOGIN_TTL_MS=300000

# GigaAM ASR (внешний сервис, отдельная команда ML-инфраструктуры).
# Polling-модель: POST /stt/transcribe → task_id, GET /stt/result/{task_id} (queued→processing→completed/error).
GIGAAM_API_URL=                              # вписать host:port от команды GigaAM
GIGAAM_API_TOKEN=                            # если требуется аутентификация
GIGAAM_POLL_INTERVAL_SECONDS=5
GIGAAM_MAX_RETRIES=3
GIGAAM_CONCURRENT_LIMIT=5                    # ТЗ 3.2.3 — лимит in-flight задач, по умолчанию 5

# SMTP — используется и backend'ом (приглашения ВКС, отчёты),
# и Grafana (алерты). Если оставить пусто — алерты Grafana не уйдут.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=toolkit@example.com
SMTP_FROM_NAME=Toolkit
SMTP_SKIP_VERIFY=false           # true — для self-signed сертификата SMTP

# Email-адрес(а) для Grafana-алертов, через запятую
ALERT_EMAIL_TO=ops@example.com

# JWT-секрет для Toolkit access-токенов
JWT_SECRET=generate-a-long-random-string-here-min-64-chars

# Публичный origin Toolkit. Должен совпадать с URL приложения в Bitrix24.
TOOLKIT_BASE_URL=https://toolkit.example.com
TOOLKIT_CORS_ORIGINS=https://toolkit.example.com

# Bootstrap admins (comma-separated emails из Bitrix24)
TOOLKIT_BOOTSTRAP_ADMINS=
